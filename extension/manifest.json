{
  "manifest_version": 3,
  "name": "BOSS Agent Greeting Assistant",
  "version": "0.2.0",
  "description": "Generate tailored BOSS greeting messages from the visible job detail page.",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/job_detail/*",
        "https://www.zhipin.com/web/geek/jobs*",
        "https://www.zhipin.com/web/geek/chat*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "https://www.zhipin.com/job_detail/*",
    "https://www.zhipin.com/web/geek/jobs*",
    "https://www.zhipin.com/web/geek/chat*"
  ]
}
